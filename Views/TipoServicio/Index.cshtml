@model SistemaWeb.Models.TipoServicios

@{
    ViewData["Title"] = "Administrar tipos de servicio";
}

<div class="container w-100 mw-100 p-0">
    <div class="row align-items-stretch mx-5 mt-5 mb-5">
        <div class="col-3">
            <a class="btn btn-rojo" id="agUsuario">
                Agregar nuevo tipo de servicio
            </a>
        </div>
    </div>
    <div class="row align-items-stretch mx-5 mt-3">
        <div class="col">
            @Html.Partial("_TipoServicioVistaParcial")
        </div>
    </div>
</div>

<div class="bloqueOscuro centrarContenedor alturaTotal contenedorForm noVisible" id="agUsuarioForm">
    <div class="row w-100 rounded">
        <div class="col-6 m-auto rounded">
            <form id="identicalForm1" class="needs-validation" novalidate method="post">
                @Html.AntiForgeryToken()

                <div class="bg-rojo p-1 w-50 shadow w-auto">
                    <h5 class="m-0 text-center text-white fw-normal fw-bold py-1">Agregar nueva tipo</h5>
                </div>

                <div class="bg-white py-3 px-3">
                    <div class="mb-3">
                        <label for="tipo" class="form-label normal">Nombre de tipo</label>
                        <input maxlength="25" type="text" class="form-control" name="tipo" pattern="([A-Z]+[\s]?[A-Z]*)+" required autofocus onkeyup="convertirMayuscula(this);" />
                        <div class="invalid-feedback">
                            Utiliza solo letras MAYUSCULAS y espacios
                        </div>
                    </div>
                    <div class="pb-2 mt-3">
                        <button id="submitBtn" type="submit" class="btn-rojo btn">Añadir nuevo tipo de servicio</button>
                        <a id="agUsuarioClose" class="btn-rojo btn float-end">Cerrar</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@{
    if (ViewBag.Editar == true || ViewBag.op != null || ViewBag.error != null)
    {

        <div class="bloqueOscuro centrarContenedor alturaTotal contenedorForm" id="agUsuarioForm">
            <div class="row w-100 rounded">
                <div class="col-6 m-auto rounded">
                    <div class="bg-rojo p-1 w-50 shadow w-auto">
                        @{
                            if (ViewBag.op == null)
                            {
                                if (ViewBag.error != null)
                                {
                                    <h5 class="m-0 text-center text-white fw-normal fw-bold py-1">Error en operación</h5>
                                }
                                else
                                {
                                    <h5 class="m-0 text-center text-white fw-normal fw-bold py-1">Ver datos de tipo de servicio</h5>
                                }
                            }
                            else
                            {
                                <h5 class="m-0 text-center text-white fw-normal fw-bold py-1">Completado</h5>
                            }
                        }

                    </div>
                    <div class="bg-white py-3 px-3">
                        @if (ViewBag.op != null || ViewBag.error != null)
                        {
                        <div>
                            @if (ViewBag.error != null)
                            {
                                <h4 class="quizLabel">@ViewBag.error</h4>
                            }
                            else if (ViewBag.op == "Agregar")
                            {
                                <h4 class="quizLabel">¡Se ha registrado el tipo de servicio <b>@ViewBag.user</b> con éxito!</h4>
                            }
                            else if (ViewBag.op == "Eliminar")
                            {
                                <h4 class="quizLabel">¡Se ha eliminado el tipo de servicio <b>@ViewBag.user</b> con éxito!</h4>
                            }
                            else if (ViewBag.op == "Actualizar")
                            {
                                <h4 class="quizLabel">¡Se ha actualizado el tipo de servicio <b>@ViewBag.user</b> con éxito!</h4>
                            }
                            <div class="row">
                                <div class="col mt-3 mb-2">
                                    @Html.ActionLink("Aceptar", "Index", new { }, new { @class = "btn-rojo btn d-block ms-auto me-auto w-fit mb-2" })
                                </div>
                            </div>
                        </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <script>

        function convertirMayuscula(e) {
            e.value = e.value.toUpperCase();
            if (e.checkValidity()) {
                e.classList.remove('is-invalid')
                e.classList.add('is-valid');

            } else {
                e.classList.remove('is-valid')
                e.classList.add('is-invalid');
            }
        }

        $(document).ready(function () {
            let currForm1 = document.getElementById('identicalForm1');

            // Validate on submit:
            currForm1.addEventListener('submit', function (event) {
                if (currForm1.checkValidity() === false) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                currForm1.classList.add('was-validated');
            }, false);


            // Validate on input:
            currForm1.querySelectorAll('.form-control').forEach(input => {
                input.addEventListener(('input'), () => {
                    if (input.checkValidity()) {
                        input.classList.remove('is-invalid')
                        input.classList.add('is-valid');

                    } else {
                        input.classList.remove('is-valid')
                        input.classList.add('is-invalid');
                    }
                });
            });


            const boton = document.querySelector("#agUsuario");
            // Agregar listener
            boton.addEventListener("click", function (evento) {
                var element = document.getElementById("agUsuarioForm");
                element.classList.remove("noVisible");
            });

            const botonCerrar = document.querySelector("#agUsuarioClose");
            // Agregar listener
            botonCerrar.addEventListener("click", function (evento) {
                var element = document.getElementById("agUsuarioForm");
                element.classList.add("noVisible");
            });
        });
    </script>

}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
