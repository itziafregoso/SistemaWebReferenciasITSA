                            </div>

                            <div class="mb-3">
                                <label for="adminalumnos" class="form-check-label normal">Administrar alumnos</label>
                                <input type="checkbox" name="adminalumnos" id="adminalumnos" class="form-check-input" />
                            </div>

                            <div class="mb-3">
                                <label for="verhistorico" class="form-check-label normal">Ver histórico</label>
                                <input type="checkbox" name="verhistorico" id="verhistorico" class="form-check-input" />
                            </div>
                        </div>
                        <div class="col">
                            <div class="mb-3">
                                <label for="verservicios" class="form-check-label normal">Ver servicios</label>
                                <input type="checkbox" name="verservicios" id="verservicios" class="form-check-input" />
                            </div>

                            <div class="mb-3">
                                <label for="administrarareas" class="form-check-label normal">Administrar áreas</label>
                                <input type="checkbox" name="administrarareas" id="administrarareas" class="form-check-input" />
                            </div>

