                        <div class="col">
                            <div class="mb-3">
                                <label for="adminperfiles" class="form-check-label normal">Administrar perfiles</label>
                                <input type="checkbox" name="adminperfiles" id="adminperfiles" class="form-check-input" />
                            </div>

                            <div class="mb-3">
                                <label for="adminusuarios" class="form-check-label normal">Administrar usuarios</label>
                                <input type="checkbox" name="adminusuarios" id="adminusuarios" class="form-check-input" />
                            </div>

