@model SistemaWeb.Models.Servicios

@{
    ViewBag.Title = "Administrar servicios";
}


<div class="container w-100 mw-100 p-0">
    <div class="row align-items-stretch mx-5 mt-5 mb-3">
        <div class="col-2">
            <a class="btn btn-rojo" id="agUsuario">
                Agregar nuevo servicio
            </a>
        </div>
        <div class="col-2">
            <a class="btn btn-rojo" id="agUsuario">
                Generar reporte
            </a>
        </div>
    </div>
    <div class="row align-items-stretch mx-5 mt-3">
        <div class="col">
            @Html.Partial("_ServiciosVistaParcial")
        </div>
    </div>
</div>


<div class="bloqueOscuro centrarContenedor alturaTotal contenedorForm" id="agUsuarioForm">
    <div class="row w-100 rounded">
        <div class="col-6 m-auto rounded">
            <div class="bg-rojo p-1 w-50 shadow w-auto">
                @{
                    if (ViewBag.msg == "Actualizar")
                    {
                        <h5 class="m-0 text-center text-white fw-normal fw-bold py-1">Actualizar datos de servicio</h5>
                    }
                    else
                    {
                        <h5 class="m-0 text-center text-white fw-normal fw-bold py-1">Confirmación</h5>
                    }
                }

            </div>
            <div class="bg-white py-3 px-3">
                @using (Html.BeginForm(null, null, FormMethod.Post, new { id = "identicalForm1" }))
                {
                    <input type="hidden" value="@ViewBag.msg" name="op" />
                    @Html.AntiForgeryToken()

                    <div>
                        @if (ViewBag.msg == "Eliminar")
                        {
                            <h4 class="quizLabel">¿Está seguro de eliminar el servicio <b>@(ViewBag.nombre)</b>?</h4>
                        }
                        else if (ViewBag.msg == "Confirmar")
                        {
                            <h4 class="quizLabel">¿Está seguro de actualizar el servicio <b>@(ViewBag.nombre)</b>?</h4>
                        }
                    </div>

                    if (ViewBag.msg == "Actualizar")
                    {

                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                        @Html.HiddenFor(model => model.contro)

                        <div class="row">
                            <div class="col">
                                <div class="mb-2">
                                    <label for="nomservicio" class="form-label normal">Nombre de servicio</label>
                                    <input maxlength="30" type="text" class="form-control w-100" name="nomservicio" value="@Model.nomservicio" pattern="([A-Z]+[\s]?[A-Z]*)+" required autofocus onkeyup="convertirMayuscula(this);" />
                                    <div class="invalid-feedback textoLeyenda">
                                        Solo se admiten letras mayúsculas sin acentos
                                    </div>
                                </div>
                            </div>
                            <div class="col">
                                <div class="mb-2 mt-5">
                                    <label for="estado" class="form-check-label normal">Servicio activo</label>
                                    @Html.EditorFor(model => model.estado, new { htmlAttributes = new { @class = "form-check-input" } })
                                </div>
                            </div>
                        </div>


                        <div class="row align-items-stretch">
                            <div class="col">
                                <div class="mb-2">
                                    <label for="IdArea" class="form-label normal">Área</label>
                                    @Html.DropDownList("IdArea", null, htmlAttributes: new { @class = "form-control form-select" })
                                </div>
                                <div class="mb-2">
                                    <label for="IdTS" class="form-label normal">Tipo de servicio</label>
                                    @Html.DropDownList("IdTS", null, htmlAttributes: new { @class = "form-control form-select" })
                                </div>
                                <div class="mb-2">
                                    <label for="Objetivo" class="form-label normal">Objetivo</label>
                                    <input maxlength="150" type="text" class="form-control" name="Objetivo" value="@Model.Objetivo" pattern="([A-Z]+[\s]?[A-Z]*)+" onkeyup="convertirMayuscula(this);" />
                                    <div class="invalid-feedback textoLeyenda">
                                        Solo se admiten letras mayúsculas sin acentos
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label for="serviciosmaxacobrar" class="form-label normal">Servicios máximos a cobrar</label>
                                    <input type="number" min="1" value=@Model.serviciosmaxacobrar name="serviciosmaxacobrar" class="d-block form-control" pattern="\d*" required />
                                    <div class="invalid-feedback textoLeyenda">
                                        Solo se admiten números enteros
                                    </div>
                                </div>
                            </div>
                            <div class="col">
                                <div class="mb-2">
                                    <label for="duracion" class="form-label normal">Duración</label>
                                    <input maxlength="15" type="text" class="form-control" name="duracion" value="@Model.duracion" pattern="^[A-Z0-9 ]*$" onkeyup="convertirMayuscula(this);" />
                                    <div class="invalid-feedback textoLeyenda">
                                        Ingresa los datos correctamente
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label for="costo" class="form-label normal">Costo</label>
                                    <input maxlength="8" type="text" class="form-control" name="costo" value="@Model.costo" placeholder="0.00" pattern="[0-9]{1,5}[.][0-9]{2}" required />
                                    <div class="invalid-feedback textoLeyenda">
                                        Ingresa los datos correctamente
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label for="cuetacontable" class="form-label normal">Cuenta contable</label>
                                    <input maxlength="3" type="text" class="form-control" name="cuetacontable" value="@Model.cuetacontable" pattern="[0-9]*$" required />
                                    <div class="invalid-feedback textoLeyenda">
                                        Solo se admiten números enteros
                                    </div>
                                </div>

                                <div class="mb-2">
                                    <label for="diasvigencia" class="form-label normal">Días de vigencia</label>
                                    <input type="number" min="1" value=@Model.diasvigencia name="diasvigencia" class="d-block form-control" pattern="\d*" required />
                                    <div class="invalid-feedback textoLeyenda">
                                        Solo se admiten números enteros
                                    </div>
                                </div>
                            </div>
                            <div class="col">
                                <div class="mb-1">
                                    <label for="prerrequisitos" class="form-label normal">Prerrequisitos</label>
                                    <textarea maxlength="150" class="form-control txtArea" name="prerrequisitos">@Model.prerrequisitos</textarea>
                                </div>
                            </div>
                        </div>

                        <script>
                            $(document).ready(function () {
                                document.getElementById("IdArea").value = @Model.IdArea;
                                document.getElementById("IdTS").value = @Model.IdTS;
                            });
                        </script>
                    }

                    <div class="row align-items-stretch mt-2">
                        <div class="col">
                            <div class="pb-2 mt-4">
                                @if (ViewBag.msg == "Actualizar")
                                {
                                    <button id="submitBtn" type="submit" class="btn-rojo btn">Actualizar información</button>
                                }
                                else
                                {
                                    <button id="submitBtn" type="submit" class="btn-rojo btn">Sí</button>
                                }
                            </div>
                        </div>
                        <div class="col">
                            <div class="pb-2 mt-4">
                                @if (ViewBag.msg == "Actualizar")
                                {
                                    @Html.ActionLink("Cancelar", "Index", new { }, new { @class = "btn-rojo btn d-block ms-auto me-0 w-fit" })
                                }
                                else
                                {
                                    @Html.ActionLink("No", "Index", new { }, new { @class = "btn-rojo btn d-block ms-auto me-0 w-fit" })
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>

    function convertirMayuscula(e) {
        e.value = e.value.toUpperCase();
        if (e.checkValidity()) {
            e.classList.remove('is-invalid')
            e.classList.add('is-valid');

        } else {
            e.classList.remove('is-valid')
            e.classList.add('is-invalid');
        }
    }

    $(document).ready(function () {

        let currForm1 = document.getElementById('identicalForm1');

        // Validate on submit:
        currForm1.addEventListener('submit', function (event) {
            if (currForm1.checkValidity() === false) {
                event.preventDefault();
                event.stopPropagation();
            }
            currForm1.classList.add('was-validated');
        }, false);


        // Validate on input:
        currForm1.querySelectorAll('.form-control').forEach(input => {
            input.addEventListener(('input'), () => {
                if (input.checkValidity()) {
                    input.classList.remove('is-invalid')
                    input.classList.add('is-valid');
                } else {
                    input.classList.remove('is-valid')
                    input.classList.add('is-invalid');
                }
            });
        });

        const boton = document.querySelector("#agUsuario");
        // Agregar listener
        boton.addEventListener("click", function (evento) {
            var element = document.getElementById("agUsuarioForm");
            element.classList.remove("noVisible");
        });
    });
</script>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
