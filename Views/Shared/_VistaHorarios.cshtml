@model SistemaWeb.Models.DiasHabiles
@Scripts.Render("~/bundles/jquery")

<script type="text/javascript">
    $(document).ready(function () {
        $("#tblUser").DataTable({
            "processing": true,
            "serverSide": true,
            "ajax": {
                "url": "@Url.Content("~/Perfil/JsonHorarios")",
                "type": "POST",
                "datatype":"json"
            },
            "pageLength": 10,
            "filter": false,
            "responsivePriority": 1,
            "data": null,
            "columns": [
                {
                    "data": "IdFecha", "name": "IdFecha", "autoWidth": true, "render":
                        function (data) {
                            return "<a class='botonEliminar' href='/Perfil/ParametrosSistema/" + data + "'>" + "<i class='fa-solid fa-trash'></i></a>";
                        },
                    "orderable": false,
                    "searchable": false,
                    "width": "35px"
                },
                {
                    "data": "fecha", "name": "fecha", "autoWidth": true, "render":
                        function (data) {
                            var valorNum = parseInt(data.replace(/\/Date\((-?\d+)\)\//, '$1'));
                            var fechaJs = new Date(valorNum);
                            return fechaJs.getDate() + "/" + (fechaJs.getMonth() + 1) + "/" + fechaJs.getFullYear();
                        },
                    "autoWidth": true
                },
            ],
            "order": [[1, "asc"]],
            "ColumnDefs": [
                { "bSortable": false, "aTargets": [1] },
            ],
            language: {
                "decimal": "",
                "emptyTable": "No hay información",
                "info": "",
                "infoEmpty": "",
                "infoFiltered": "",
                "infoPostFix": "",
                "thousands": ",",
                "lengthMenu": "",
                "loadingRecords": "Cargando...",
                "processing": "Procesando...",
                "search": "Buscar:",
                "zeroRecords": "Sin resultados encontrados",
                "paginate": {
                    "first": "Primero",
                    "last": "Ultimo",
                    "next": "Siguiente",
                    "previous": "Anterior"
                }
            },
        });

    });
</script>

<table id="tblUser" class="table table-striped text-center shadow-sm display" style="width:100%">
    <thead class="table-rojo">
        <tr>
            <th scope="col">Eliminar</th>
            <th scope="col">Fecha</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>