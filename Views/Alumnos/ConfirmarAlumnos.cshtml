@model SistemaWeb.Models.Clientes

@{
    ViewBag.Title = "Administrar alumnos";
}

<div class="container w-100 mw-100 p-0">
    <div class="row align-items-stretch mx-5 mt-5 mb-3">
        <div class="col-2">
            <a class="btn btn-rojo" id="agUsuario">
                Agregar nuevo alumno
            </a>
        </div>
        <div class="col-2">
            <a class="btn btn-rojo" id="agUsuario">
                Generar reporte
            </a>
        </div>
    </div>
    <div class="row align-items-stretch mx-5 mt-3">
        <div class="col">
            @Html.Partial("_AlumnosVistaParcial")
        </div>
    </div>
</div>


<div class="bloqueOscuro centrarContenedor alturaTotal contenedorForm" id="agUsuarioForm">
    <div class="row w-100 rounded">
        <div class="col-6 m-auto rounded">
            <div class="bg-rojo p-1 w-50 shadow w-auto">
                @{
                    if (ViewBag.msg == "Actualizar")
                    {
                        <h5 class="m-0 text-center text-white fw-normal fw-bold py-1">Actualizar datos de alumno</h5>
                    }
                    else
                    {
                        <h5 class="m-0 text-center text-white fw-normal fw-bold py-1">Confirmación</h5>
                    }
                }

            </div>
            <div class="bg-white py-3 px-3">
                @using (Html.BeginForm(null, null, FormMethod.Post, new { id = "identicalForm1" }))
                {
                    <input type="hidden" value="@ViewBag.msg" name="op" />
                    @Html.AntiForgeryToken()

                    <div>
                        @if (ViewBag.msg == "Eliminar")
                        {
                            <h5 class="quizLabel">¿Está seguro de eliminar el alumno <b>@(ViewBag.nombre)</b>?</h5>
                        }
                        else if (ViewBag.msg == "Confirmar")
                        {
                            <h5 class="quizLabel">¿Está seguro de actualizar el alumno <b>@(ViewBag.nombre)</b>?</h5>
                        }
                    </div>

                    if (ViewBag.msg == "Actualizar")
                    {
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                        @Html.HiddenFor(model => model.IdCliente)

                        @Html.HiddenFor( model => model.tipopersona)
                        @Html.HiddenFor( model => model.rfc_)

                        <div class="row">
                            <div class="col">
                                <div class="mb-3">
                                    <label for="nombre_" class="form-label normal">Nombre</label>
                                    <input name="nombre_" value="@Model.nombre_" maxlength="30" type="text" class="form-control" pattern="([A-Z]+[\s]?[A-Z]*)+" required autofocus onkeyup="convertirMayuscula(this);" />
                                    <div class="invalid-feedback textoLeyenda">
                                        Solo se admiten letras mayúsculas sin acentos
                                    </div>
                                </div>
                            </div>

                            <div class="col">
                                <div class="mb-3">
                                    <label for="apellidos" class="form-label normal">Apellidos</label>
                                    <input value="@Model.apellidos" maxlength="30" type="text" class="form-control" name="apellidos" pattern="([A-Z]+[\s]?[A-Z]*)+" required onkeyup="convertirMayuscula(this);" />
                                    <div class="invalid-feedback textoLeyenda">
                                        Solo se admiten letras mayúsculas sin acentos
                                    </div>
                                </div>
                            </div>

                            <div class="col">
                                <div class="mb-3">
                                    <label for="matricula" class="form-label normal">Matrícula</label>
                                    <input value="@Model.matricula" id="matricula" maxlength="9" type="text" class="form-control" name="matricula" pattern="(((ISC)|(LG)|(IB)|(IE)|(II)|(IM))[0-9]{6})" required onkeyup="convertirMayuscula(this);" />
                                    <div class="invalid-feedback textoLeyenda">
                                        Solo se admiten letras mayúsculas y números
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row align-items-stretch">
                            <div class="col">

                                @{
                                    var txt = "([A-Za-z0-9]+[._]*[A-Za-z0-9]*)+(@itsatlixco.edu.mx)";
                                }

                                <div class="mb-3">
                                    <label for="correoelectronico" class="form-label normal">Correo electrónico</label>
                                    <input value="@Model.correoelectronico" maxlength="60" type="email" class="form-control" name="correoelectronico" id="correo" pattern="@txt" required />
                                    <div class="invalid-feedback textoLeyenda">
                                        Ingresa un correo electrónico institucional
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row align-items-stretch">
                            <div class="col">
                                <div class="mb-3">
                                    <label for="calle" class="form-label normal">Calle</label>
                                    <input value="@Model.calle" maxlength="30" id="calle" type="text" class="form-control" name="calle" pattern="(([A-Z]|[0-9])+[ ]?[.]?[ ]?(([A-Z]|[0-9])+[.]?[ ]?[A-Z]*[0-9]*[.]?[ ]?)*([A-Z]|[0-9])+)" required onkeyup="convertirMayuscula(this);" />
                                    <div class="invalid-feedback textoLeyenda">
                                        Ingresa un nombre correcto
                                    </div>
                                </div>
                            </div>
                            <div class="col">
                                <div class="mb-3">
                                    <label for="numeroex" class="form-label normal">Número exterior</label>
                                    <input value="@Model.numeroex" maxlength="10" id="numeroex" type="text" class="form-control" pattern="((SN)|[0-9]+[ ][A-Z]+|(ED)[ ][0-9]+|[0-9]+)" name="numeroex" required onkeyup="convertirMayuscula(this);" />
                                    <div class="invalid-feedback textoLeyenda">
                                        Ingresa un número exterior válido
                                    </div>
                                </div>
                            </div>
                            <div class="col">
                                <div class="mb-3">
                                    <label for="numeroin" class="form-label normal">Número interior</label>
                                    <input value="@Model.numeroin" maxlength="5" id="numeroin" type="text" class="form-control" pattern="([0-9]+[ ][A-Z]+|(D)[ ][0-9]+|[0-9]+)" name="numeroin" onkeyup="convertirMayuscula(this);" />
                                    <div class="invalid-feedback textoLeyenda">
                                        Ingresa un número interior válido
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row align-items-stretch">
                            <div class="col">
                                <div class="mb-3">
                                    <label for="colonia" class="form-label normal">Colonia</label>
                                    <input value="@Model.colonia" maxlength="30" id="colonia" type="text" class="form-control" name="colonia" pattern="(([A-Z]|[0-9])+[ ]?[.]?[ ]?(([A-Z]|[0-9])+[.]?[ ]?[A-Z]*[0-9]*[.]?[ ]?)*([A-Z]|[0-9])+)" required onkeyup="convertirMayuscula(this);" />
                                    <div class="invalid-feedback textoLeyenda">
                                        Ingresa una colonia válida
                                    </div>
                                </div>
                            </div>
                            <div class="col">
                                <div class="mb-3">
                                    <label for="cp" class="form-label normal">Código postal</label>
                                    <input value="@Model.cp" maxlength="10" id="cp" type="text" class="form-control" name="cp" pattern="[0-9]{5}" required onkeyup="convertirMayuscula(this);" />
                                    <div class="invalid-feedback textoLeyenda">
                                        Ingresa un código postal válido
                                    </div>
                                </div>
                            </div>
                            <div class="col">
                                <div class="mb-3">
                                    <label for="ciudad" class="form-label normal">Ciudad</label>
                                    <input value="@Model.ciudad" maxlength="30" id="ciudad" type="text" class="form-control" name="ciudad" pattern="([A-Z]+[\s]?[A-Z]*)+" required onkeyup="convertirMayuscula(this);" />
                                    <div class="invalid-feedback textoLeyenda">
                                        Ingresa una ciudad válida
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row align-items-stretch">
                            <div class="col">
                                <div class="mb-3">
                                    <label for="estado" class="form-label normal">Estado</label>
                                    <input value="@Model.estado" maxlength="30" id="estado" type="text" class="form-control" name="estado" pattern="([A-Z]+[\s]?[A-Z]*)+" required onkeyup="convertirMayuscula(this);" />
                                    <div class="invalid-feedback textoLeyenda">
                                        Ingresa un estado válido
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="row align-items-stretch mt-2">
                        <div class="col">
                            <div class="pb-2 mt-4">
                                @if (ViewBag.msg == "Actualizar")
                                {
                                    <button id="submitBtn" type="submit" class="btn-rojo btn">Actualizar información</button>
                                }
                                else
                                {
                                    <button id="submitBtn" type="submit" class="btn-rojo btn">Sí</button>
                                }
                            </div>
                        </div>
                        <div class="col">
                            <div class="pb-2 mt-4">
                                @if (ViewBag.msg == "Actualizar")
                                {
                                    @Html.ActionLink("Cancelar", "Index", new { }, new { @class = "btn-rojo btn d-block ms-auto me-0 w-fit" })
                                }
                                else
                                {
                                    @Html.ActionLink("No", "Index", new { }, new { @class = "btn-rojo btn d-block ms-auto me-0 w-fit" })
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>

    function convertirMayuscula(e) {
        e.value = e.value.toUpperCase();
        if (e.checkValidity()) {
            e.classList.remove('is-invalid')
            e.classList.add('is-valid');

        } else {
            e.classList.remove('is-valid')
            e.classList.add('is-invalid');
        }
    }

    $(document).ready(function () {
        let currForm1 = document.getElementById('identicalForm1');

        $("#contrasena, #confirmarcontrasena").on("keyup", function () {
            // store the `newPassword` and `confirmPassword` in two variables
            var newPasswordValue = $("#contrasena").val();
            var confirmPasswordValue = $("#confirmarcontrasena").val();

            if (newPasswordValue.length > 0 && confirmPasswordValue.length > 0) {
                if (confirmPasswordValue !== newPasswordValue) {
                    $("#confirmarcontrasena").addClass('is-invalid');
                }
                if (confirmPasswordValue === newPasswordValue) {
                    $("#confirmarcontrasena").addClass('is-valid');
                }
            }
        });

        // Validate on submit:
        currForm1.addEventListener('submit', function (event) {
            if (currForm1.checkValidity() === false) {
                event.preventDefault();
                event.stopPropagation();
            }
            currForm1.classList.add('was-validated');
        }, false);


        // Validate on input:
        currForm1.querySelectorAll('.form-control').forEach(input => {
            input.addEventListener(('input'), () => {
                if (input.checkValidity()) {
                    input.classList.remove('is-invalid')
                    input.classList.add('is-valid');
                    var correoValor = $("#correo").val();

                } else {
                    input.classList.remove('is-valid')
                    input.classList.add('is-invalid');
                }
            });
        });

        const boton = document.querySelector("#agUsuario");
        // Agregar listener
        boton.addEventListener("click", function (evento) {
            var element = document.getElementById("agUsuarioForm");
            element.classList.remove("noVisible");
        });
    });
</script>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}