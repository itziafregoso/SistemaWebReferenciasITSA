@model SistemaWeb.Models.UsuariosAd

@{
    ViewBag.Title = "Administrar usuarios";
}

<div class="container w-100 mw-100 p-0">
    <div class="row align-items-stretch mx-5 mt-5 mb-3">
        <div class="col-2">
            <a class="btn btn-rojo" id="agUsuario">
                Agregar nuevo usuario
            </a>
        </div>
        <div class="col-2">
            <a class="btn btn-rojo" id="reporteBtn">
                Generar reporte
            </a>
        </div>
    </div>
    <div class="row align-items-stretch mx-5 mt-3">
        <div class="col">
            @Html.Partial("_UsuariosVistaParcial")
        </div>
    </div>
</div>

<div class="bloqueOscuro centrarContenedor alturaTotal contenedorForm noVisible" id="agUsuarioForm">
    <div class="row w-100 rounded">
        <div class="col-6 m-auto rounded">
            <form id="identicalForm1" class="needs-validation" novalidate method="post">
                <div class="bg-rojo p-1 w-50 shadow w-auto">
                    <h5 class="m-0 text-center text-white fw-normal fw-bold py-1">Agregar nuevo usuario</h5>
                </div>

                <div class="bg-white py-3 px-3">
                    <div class="row">
                        <div class="col">
                            <div class="mb-3">
                                <label for="nombre" class="form-label normal">Nombre</label>
                                <input maxlength="30" type="text" class="form-control" name="nombre" pattern="([A-Z]+[\s]?[A-Z]*)+" required autofocus onkeyup="convertirMayuscula(this);" />
                                <div class="invalid-feedback textoLeyenda">
                                    Solo se admiten letras mayúsculas sin acentos
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="mb-3 mt-5">
                                <label for="estado" class="form-check-label normal">Usuario activo</label>
                                <input type="checkbox" name="estado" class="form-check-input" />
                            </div>
                        </div>
                    </div>
                    <div class="row align-items-stretch">
                        <div class="col">
                            <div class="mb-3">
                                <label for="iniciales" class="form-label normal">Iniciales</label>
                                <input maxlength="4" type="text" class="form-control" name="iniciales" pattern="[A-Z][A-Z][A-Z][A-Z]?" required onkeyup="convertirMayuscula(this);" />
                                <div class="invalid-feedback textoLeyenda">
                                    Solo se admiten letras mayúsculas sin acentos
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="IdPerfil" class="form-label normal">Perfil</label>
                                @Html.DropDownList("IdPerfil", null, htmlAttributes: new { @class = "form-control form-select" })
                            </div>

                            <div class="mb-3">
                                <label for="contrasena" class="form-label normal">Contraseña</label>
                                <input maxlength="20" type="password" class="form-control" name="contrasena" id="contrasena" pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}" required>
                                <div class="invalid-feedback textoLeyenda">
                                    Incluye al menos 8 carácteres, un número y una letra mayúscula
                                </div>
                            </div>

                        </div>
                        <div class="col">

                            @{
                                var txt = "([A-Za-z0-9]+[._]*[A-Za-z0-9]*)+(@itsatlixco.edu.mx)";
                            }

                            <div class="mb-3">
                                <label for="correoelectronico" class="form-label normal">Correo electrónico</label>
                                <input maxlength="60" type="email" class="form-control" name="correoelectronico" id="correo" pattern="@txt" required />
                                <div class="invalid-feedback textoLeyenda">
                                    Ingresa un correo electrónico institucional
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="IdAreaAd" class="form-label normal">Área administrativa</label>
                                @Html.DropDownList("IdAreaAd", null, htmlAttributes: new { @class = "form-control form-select" })
                            </div>

                            <div class="mb-3">
                                <label for="confirmarcontrasena" class="form-label normal">Confirmar contraseña</label>
                                <input maxlength="20" type="password" class="form-control" name="confirmarcontrasena" id="confirmarcontrasena" pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}" required />
                                <div id="cPwdInvalid" class="invalid-feedback textoLeyenda">
                                    Las contraseñas no coinciden
                                </div>
                            </div>

                        </div>
                    </div>

                    <div class="row align-items-stretch">
                        <div class="col">
                            <div class="col">
                                <div class="pb-2 mt-3">
                                    <button id="submitBtn" type="submit" class="btn-rojo btn">Añadir nuevo usuario</button>
                                    <a id="agUsuarioClose" class="btn-rojo btn float-end">Cerrar</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="bloqueOscuro centrarContenedor alturaTotal contenedorForm noVisible" id="reporteForm">
    <div class="row w-100 rounded">
        <div class="col-6 m-auto rounded">
            @using (Html.BeginForm("GenerarReporte", "Usuarios"))
            {
                <div class="bg-rojo p-1 w-50 shadow w-auto">
                    <h5 class="m-0 text-center text-white fw-normal fw-bold py-1">Generar reporte Excel</h5>
                </div>

                <div class="bg-white py-3 px-3">
                    <div class="row mb-3">
                        <div class="col">
                            <div class="mb-3">
                                <label for="estadoRep" class="form-label normal">Estado de usuario:</label>
                                <select id="estadoRep" class="form-control form-select" name="estadoRep">
                                    <option value="">TODOS</option>
                                    <option value="ACTIVO">ACTIVO</option>
                                    <option value="INACTIVO">INACTIVO</option>
                                </select>
                            </div>
                        </div>
                        <div class="col">
                            <div class="mb-3">
                                <label for="perfilRep" class="form-label normal">Tipo de perfil:</label>
                                @Html.DropDownList("perfilRep", (IEnumerable<SelectListItem>)ViewBag.IdPerfil, "TODOS", htmlAttributes: new { @class = "form-control form-select" })
                            </div>
                        </div>
                        <div class="col">
                            <div class="mb-3">
                                <label for="areaRep" class="form-label normal">Tipo de área:</label>
                                @Html.DropDownList("areaRep", (IEnumerable<SelectListItem>)ViewBag.IdAreaAd, "TODAS", htmlAttributes: new { @class = "form-control form-select" })
                            </div>
                        </div>
                    </div>

                    <div class="row align-items-stretch">
                        <div class="col">
                            <div class="col">
                                <div class="pb-2 mt-3">
                                    <button id="submitBtn" type="submit" class="btn-rojo btn">Descargar Excel</button>
                                    <a id="reporteClose" class="btn-rojo btn float-end">Cerrar</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>


@{
    if (ViewBag.Editar == true || ViewBag.op != null || ViewBag.error != null)
    {
        <div class="bloqueOscuro centrarContenedor alturaTotal contenedorForm" id="agUsuarioForm">
            <div class="row w-100 rounded">
                <div class="col-6 m-auto rounded">
                    <div class="bg-rojo p-1 w-50 shadow w-auto">
                        @{
                            if (ViewBag.op == null)
                            {
                                if (ViewBag.error != null)
                                {
                                    <h5 class="m-0 text-center text-white fw-normal fw-bold py-1">Error en operación</h5>
                                }
                                else
                                {
                                    <h5 class="m-0 text-center text-white fw-normal fw-bold py-1">Ver datos de usuario</h5>
                                }
                            }
                            else
                            {
                                <h5 class="m-0 text-center text-white fw-normal fw-bold py-1">Completado</h5>
                            }
                        }

                    </div>
                    <div class="bg-white py-3 px-3">
                        @if (ViewBag.op != null || ViewBag.error != null)
                        {
                        <div>
                            @if (ViewBag.error != null)
                            {
                                <h4 class="quizLabel">@ViewBag.error</h4>
                            }
                            else if (ViewBag.op == "Agregar")
                            {
                                <h4 class="quizLabel">¡Se ha registrado el usuario <b>@ViewBag.user</b> con éxito!</h4>
                            }
                            else if (ViewBag.op == "Eliminar")
                            {
                                <h4 class="quizLabel">¡Se ha eliminado el usuario <b>@ViewBag.user</b> con éxito!</h4>
                            }
                            else if (ViewBag.op == "Actualizar")
                            {
                                <h4 class="quizLabel">¡Se ha actualizado el usuario <b>@ViewBag.user</b> con éxito!</h4>
                            }
                            <div class="row">
                                <div class="col mt-3 mb-2">
                                    @Html.ActionLink("Aceptar", "Index", new { }, new { @class = "btn-rojo btn d-block ms-auto me-auto w-fit mb-2" })
                                </div>
                            </div>
                        </div>
                        }
                        else
                        {
                    <div class="px-3 m-3">
                        @using (Html.BeginForm())
                        {
                            @Html.AntiForgeryToken()

                            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                            @Html.HiddenFor(model => model.IdUsuariosAd)

                            <h3 class="fw-bold text-rojo d-inline-block">@Model.nombre</h3>

                            <div class="d-inline-block position-absolute mx-3">
                                @if (Model.estado == true)
                                {
                                    <span class='badge bg-success mt-1'>Activo</span>
                                }
                                else
                                {
                                    <span class='badge bg-danger mt-1'>Inactivo</span>
                                }
                            </div>

                            <div class="row align-items-stretch mt-4">
                                <div class="col">
                                    <div class="mb-2">
                                        <label for="nombre" class="form-label normal">Nombre</label>
                                        <input maxlength="30" type="text" class="form-control" name="nombre" readonly value="@Model.nombre" />
                                    </div>

                                    <div class="mb-2">
                                        <label for="iniciales" class="form-label normal">Iniciales</label>
                                        <input maxlength="4" type="text" class="form-control" name="iniciales" readonly value="@Model.iniciales" />
                                    </div>

                                    <div class="mb-2">
                                        <label for="IdPerfil" class="form-label normal">Perfil</label>
                                        <input type="text" class="form-control" name="IdPerfil" readonly value="@Model.PerfilesAd.nombreperfil" />
                                    </div>
                                </div>
                                <div class="col">

                                    <div class="mb-2">
                                        <label for="correoelectronico" class="form-label normal">Correo electrónico</label>
                                        <input type="text" class="form-control" name="correoelectronico" readonly value="@Model.correoelectronico" />
                                    </div>

                                    <div class="mb-2">
                                        <label for="IdAreaAd" class="form-label normal">Área administrativa</label>
                                        <input type="text" class="form-control" name="IdAreaAd" readonly value="@Model.AreasAd.nombrearead" />
                                    </div>
                                </div>
                            </div>

                            <div class="row align-items-stretch">
                                <div class="col">
                                    <div class="col">
                                        <div class="pb-2 mt-3">
                                            <a href="/Usuarios" class="btn-rojo btn float-end">Cerrar</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <script>

        function convertirMayuscula(e) {
            e.value = e.value.toUpperCase();
            if (e.checkValidity()) {
                e.classList.remove('is-invalid')
                e.classList.add('is-valid');

            } else {
                e.classList.remove('is-valid')
                e.classList.add('is-invalid');
            }
        }

        $(document).ready(function () {
            let currForm1 = document.getElementById('identicalForm1');

            $("#contrasena, #confirmarcontrasena").on("keyup", function () {
                // store the `newPassword` and `confirmPassword` in two variables
                var newPasswordValue = $("#contrasena").val();
                var confirmPasswordValue = $("#confirmarcontrasena").val();

                if (newPasswordValue.length > 0 && confirmPasswordValue.length > 0) {
                    if (confirmPasswordValue !== newPasswordValue) {
                        $("#confirmarcontrasena").addClass('is-invalid');
                    }
                    if (confirmPasswordValue === newPasswordValue) {
                        $("#confirmarcontrasena").addClass('is-valid');
                    }
                }
            });

            // Validate on submit:
            currForm1.addEventListener('submit', function (event) {
                if (currForm1.checkValidity() === false) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                currForm1.classList.add('was-validated');
            }, false);


            // Validate on input:
            currForm1.querySelectorAll('.form-control').forEach(input => {
                input.addEventListener(('input'), () => {
                    if (input.checkValidity()) {
                        input.classList.remove('is-invalid')
                        input.classList.add('is-valid');
                        var correoValor = $("#correo").val();

                    } else {
                        input.classList.remove('is-valid')
                        input.classList.add('is-invalid');
                    }
                });
            });

            const boton = document.querySelector("#agUsuario");
            // Agregar listener
            boton.addEventListener("click", function (evento) {
                var element = document.getElementById("agUsuarioForm");
                element.classList.remove("noVisible");
            });

            const btnDos = document.querySelector("#reporteBtn");
            // Agregar listener
            btnDos.addEventListener("click", function (evento) {
                var elementDos = document.getElementById("reporteForm");
                elementDos.classList.remove("noVisible");
            });

            const botonCerrar = document.querySelector("#agUsuarioClose");
            // Agregar listener
            botonCerrar.addEventListener("click", function (evento) {
                var element = document.getElementById("agUsuarioForm");
                element.classList.add("noVisible");
            });

            const botonCerrar2 = document.querySelector("#reporteClose");
            // Agregar listener
            botonCerrar2.addEventListener("click", function (evento) {
                var element2 = document.getElementById("reporteForm");
                element2.classList.add("noVisible");
            });

        });
    </script>

}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}



