@Scripts.Render("~/bundles/jquery")

@{
    ViewBag.Title = "Restaurar sistema";
}

<div class="row align-items-stretch mx-5 mt-3">
    <div class="col">
        <ul class="lineaArbol">
            <li class="text-rojo textoLeyenda">
                Restaurar sistema
            </li>
        </ul>
    </div>
</div>

<div class="container w-100 mw-100 p-0">
    <div class="row align-items-stretch mx-5 mt-5">
        <div class="col">

            <div class="w-50 mx-auto text-center">
                <i class="fa-solid fa-power-off iconTitle"></i>
            </div>

            <div class="w-50 mx-auto text-center container-info">
                <i class="fa-solid fa-circle-info"></i>
                <p>
                    Esta sección tiene como objetivo reiniciar el sistema, como si se cerrara el año fiscal. Antes de iniciar este proceso, es importante tener en cuenta que toda la información registrada se moverá a un respaldo histórico, donde se registrará bajo el año @ViewBag.anio y no se podrán agregar más datos. Por lo tanto, es fundamental considerar esta información antes de proceder.
                </p>
            </div>

            @using (Html.BeginForm("Restaurar", "Respaldo", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                <div class="d-block mx-auto form-control w-50">
                    <label for="password" class="form-label normal">Contraseña de usuario</label>
                    <input type="password" class="form-control" name="password" required autofocus" />
                </div>

                if (ViewBag.mensaje != null)
                {
                    <div class="alert alert-danger w-50 mx-auto mt-3 normal" role="alert">
                        @ViewBag.mensaje
                    </div>
                }

                <div class="d-block m-auto mt-4">
                    <input class="btn btn-rojo w-50 mx-auto d-block" type="submit" value="Iniciar proceso" />
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
